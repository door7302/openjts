{
  "version": 1,
  "min-interval": 30,
  "description": "This profile provides template for collecting BGP data",
  "telegraf": {
    "vmx": [{
      "version": "all",
      "conf": "vmx_bgp.json"
    }],
    "mx": [{
      "version": "all",
      "conf": "mx_bgp.json"
    }],
    "ptx": [{
      "version": "all",
      "conf": "ptx_bgp.json"
    }],
    "acx": [{
      "version": "all",
      "conf": "acx_bgp.json"
    }],
    "qfx": [{
      "version": "all",
      "conf": "qfx_bgp.json"
    }],
    "ex": [{
      "version": "all",
      "conf": "ex_bgp.json"
    }],
    "crpd": [{
      "version": "all",
      "conf": "crpd_bgp.json"
    }],
    "vjunos": [{
      "version": "all",
      "conf": "vjunos_bgp.json"
    }],
    "vevo": [{
      "version": "all",
      "conf": "vevo_bgp.json"
    }]
  },
  "kapacitor": null,
  "grafana": [
    "dashboard-bgp.json"
  ]
}